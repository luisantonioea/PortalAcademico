@model IEnumerable<PortalAcademico.Models.Curso>
@{ ViewData["Title"] = "Panel de Coordinador - Cursos"; }

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2>Gestión de Cursos</h2>
    <a asp-action="Crear" class="btn btn-primary">Crear Nuevo Curso</a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success">@TempData["Exito"]</div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupos</th>
            <th>Horario</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.Codigo</td>
                <td>@curso.Nombre</td>
                <td>@curso.Creditos</td>
                <td>@curso.CupoMaximo</td>
                <td>@curso.HorarioInicio.ToString(@"hh\:mm") - @curso.HorarioFin.ToString(@"hh\:mm")</td>
                <td>
                    <span class="badge @(curso.Activo ? "bg-success" : "bg-danger")">
                        @(curso.Activo ? "Activo" : "Inactivo")
                    </span>
                </td>
                <td>
                    <a asp-action="Editar" asp-route-id="@curso.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Matriculas" asp-route-id="@curso.Id" class="btn btn-sm btn-info text-white">Matrículas</a>
                    
                    <form asp-action="Desactivar" asp-route-id="@curso.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm @(curso.Activo ? "btn-danger" : "btn-success")">
                            @(curso.Activo ? "Desactivar" : "Activar")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>